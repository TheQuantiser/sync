Host cmslpc301
  HostName cmslpc301.fnal.gov
  User mwadud

  SetEnv TERM=xterm-256color
  SendEnv COLORTERM TERM_PROGRAM TERM_PROGRAM_VERSION

  PreferredAuthentications gssapi-with-mic,publickey,keyboard-interactive

  GSSAPIAuthentication yes
  GSSAPIDelegateCredentials yes
  StrictHostKeyChecking no
  UserKnownHostsFile /dev/null

  # Multiplexing (critical for VS Code on lxplus)
  ControlMaster auto
  ControlPath ~/.ssh/cm-%C
  ControlPersist 60

  # Keepalive
  ServerAliveInterval 30
  ServerAliveCountMax 5
  Compression yes

  # No X11 (VS Code uses -T anyway; this avoids surprises)
  ForwardX11 no
  ForwardX11Trusted no

  # Your ticket refresh / keytab preflight
  ProxyCommand /bin/bash -lc "export KRB5CCNAME=DIR:$HOME/.krb5cc_shared; mkdir -p $HOME/.krb5cc_shared; chmod 700 $HOME/.krb5cc_shared 2>/dev/null || true; klist -s || kinit -l 168h -r 30d -k -t $HOME/.keytabs/mwadud_fnal.keytab mwadud@FNAL.GOV; exec nc %h %p"

