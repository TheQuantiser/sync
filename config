Host lxplus lxplus_vscode lxplus.cern.ch lxplus???.cern.ch
  User mwadud

  GSSAPIAuthentication yes
  GSSAPIDelegateCredentials yes
  PreferredAuthentications gssapi-with-mic,keyboard-interactive

  ControlMaster auto
  ControlPath ~/.ssh/cm-%C
  ControlPersist 300

  ServerAliveInterval 120
  ServerAliveCountMax 5
  Compression yes

  ForwardX11 no
  ForwardX11Trusted no

  ProxyCommand /bin/bash -lc "set -euo pipefail; export KRB5CCNAME=DIR:$HOME/.krb5cc_shared; mkdir -p $HOME/.krb5cc_shared; chmod 700 $HOME/.krb5cc_shared 2>/dev/null || true; kinit -l 168h -r 30d -k -t $HOME/.keytabs/mwadud_cern.keytab mwadud@CERN.CH >/dev/null; exec nc %h %p"

Host lxplus lxplus_vscode lxplus.cern.ch
  HostName lxplus.cern.ch

Host cmslpc*.fnal.gov cmslpc301 cmslpc_heavyel9 cmslpc_heavyel9_vscode
  User mwadud

  PreferredAuthentications gssapi-with-mic,publickey,keyboard-interactive
  GSSAPIAuthentication yes
  GSSAPIDelegateCredentials yes

  StrictHostKeyChecking no
  UserKnownHostsFile /dev/null

  ControlMaster auto
  ControlPath ~/.ssh/cm-%C
  ControlPersist 60

  ServerAliveInterval 30
  ServerAliveCountMax 5
  Compression yes

  ForwardX11 no
  ForwardX11Trusted no

  ProxyCommand /bin/bash -lc "set -euo pipefail; export KRB5CCNAME=DIR:$HOME/.krb5cc_shared; mkdir -p $HOME/.krb5cc_shared; chmod 700 $HOME/.krb5cc_shared 2>/dev/null || true; kinit -l 168h -r 30d -k -t $HOME/.keytabs/mwadud_fnal.keytab mwadud@FNAL.GOV >/dev/null; exec nc %h %p"

Host cmslpc301
  HostName cmslpc301.fnal.gov

Host cmslpc_heavyel9 cmslpc_heavyel9_vscode
  HostName cmslpc-el9-heavy01.fnal.gov

# CMS user head nodes
Host cmsusr cmsusr* cmsusr*.cms
  # .CMS username (from sysadmin mail)
  User mwadud
  Protocol 2
  ForwardAgent yes
  ForwardX11 yes
  ForwardX11Trusted no

  # hop via lxplus
  ProxyCommand ssh lxplus nc %h 22

  # SOCKS proxy for .cms web
  DynamicForward 1080

  # RDP forwards (Linux OpenSSH style)
  LocalForward 5389 rdp1:3389
  LocalForward 6389 rdp2:3389

  # Oracle DB forwards (usually not needed for shifts but harmless)
  LocalForward 10121 cmsonr1-v.cms:10121
  LocalForward 10122 cmsonr2-v.cms:10121
  LocalForward 10123 cmsonr3-v.cms:10121
  LocalForward 10124 cmsonr4-v.cms:10121
  LocalForward 10125 cmsintr1-v.cms:10121
  LocalForward 10126 cmsintr2-v.cms:10121

# Direct access to P5 hosts / RDP once cmsusr connection exists
Host rdp* *.cms 10.176.*.*
  User mwadud
  Protocol 2
  ForwardAgent yes
  ForwardX11 yes
  ForwardX11Trusted no
  ProxyCommand ssh cmsusr nc %h 22
